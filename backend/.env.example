# ========================================
# 刷题宝典 - 环境变量配置
# ========================================
# 复制此文件为 .env 并填入你的真实值
#   cp .env.example .env
# .env 已在 .gitignore 中，不会被提交到 Git
# ========================================

# JWT 密钥（用于用户登录令牌签名）
# 生成方式：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=在此填入你的随机密钥

# AI API Key（DashScope / 阿里云千问）
# 获取地址：https://dashscope.console.aliyun.com/apiKey
AI_API_KEY=sk-在此填入你的APIKey

# 服务端口（可选，默认 8080）
# PORT=8080

# 运行环境（production 时启用 CORS 限制等）
# NODE_ENV=production

# GitHub 同步配置（可选，用于跨设备数据同步）
# GITHUB_TOKEN=ghp_在此填入你的GitHubToken
# GITHUB_REPO=你的用户名/你的仓库名
